{
  "name": "chromatic-mastery",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev": "tsx src/index.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "play": "tsx src/cli.ts",
    "play:web": "vite",
    "test": "vitest run tests/game.test.ts",
    "test:watch": "vitest tests/game.test.ts",
    "test:e2e": "playwright test",
    "test:cloud": "npm run build && npm test && npm run test:e2e",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
